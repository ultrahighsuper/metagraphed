{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metagraph.sh/schemas/components/03-providers.schema.json",
  "title": "Metagraphed OpenAPI components 03-providers",
  "type": "object",
  "components": {
    "schemas": {
      "Provider": {
        "type": "object",
        "required": [
          "schema_version",
          "id",
          "name",
          "kind",
          "website_url",
          "authority"
        ],
        "properties": {
          "schema_version": {
            "const": 1
          },
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "$ref": "#/components/schemas/ProviderKind"
          },
          "website_url": {
            "type": "string",
            "format": "uri",
            "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
            "examples": ["https://example.com"]
          },
          "docs_url": {
            "type": "string",
            "format": "uri",
            "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
            "examples": ["https://docs.example.com"]
          },
          "github_url": {
            "type": "string",
            "format": "uri",
            "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
            "examples": ["https://github.com/example"]
          },
          "logo_url": {
            "type": "string",
            "format": "uri",
            "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
            "examples": ["https://example.com/logo.png"],
            "description": "Curated provider logo, else backfilled from the on-chain logo of the single subnet this provider operates. Display-only; never feeds completeness."
          },
          "social": {
            "type": "object",
            "additionalProperties": false,
            "description": "Structured social links: a curated provider override, else borrowed from the single subnet this provider operates. Display-only; never feeds completeness.",
            "properties": {
              "x": {
                "type": "string",
                "format": "uri",
                "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
                "examples": ["https://x.com/example"]
              },
              "telegram": {
                "type": "string",
                "format": "uri",
                "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
                "examples": ["https://t.me/example"]
              },
              "reddit": {
                "type": "string",
                "format": "uri",
                "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
                "examples": ["https://reddit.com/r/example"]
              },
              "youtube": {
                "type": "string",
                "format": "uri",
                "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
                "examples": ["https://youtube.com/@example"]
              }
            }
          },
          "team_url": {
            "type": "string",
            "format": "uri",
            "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
            "examples": ["https://example.com/team"]
          },
          "contact_url": {
            "type": "string",
            "format": "uri",
            "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
            "examples": ["https://example.com/contact"]
          },
          "authority": {
            "$ref": "#/components/schemas/Authority"
          },
          "public_notes": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "netuids": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 },
            "description": "Sorted unique netuids this provider operates a curated surface on (issue #347). Derived/reporting — never feeds completeness."
          },
          "subnet_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of distinct subnets this provider operates (netuids.length)."
          },
          "surface_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of curated surfaces attributed to this provider."
          },
          "endpoint_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of live endpoints attributed to this provider."
          },
          "cluster_id": {
            "type": "string",
            "description": "Shared-team cluster id (registrable domain of team_url/website_url, else the provider id) grouping providers run by the same team (issue #347)."
          }
        },
        "additionalProperties": false
      },
      "ProvidersArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["providers"],
            "properties": {
              "providers": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Provider"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "ProviderArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["provider"],
            "properties": {
              "provider": {
                "$ref": "#/components/schemas/Provider"
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "ProviderEndpointsArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["provider", "summary", "endpoints"],
            "properties": {
              "provider": {
                "type": "object",
                "description": "Identity summary of the provider these endpoints belong to.",
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "kind": { "type": "string" },
                  "authority": { "type": "string" }
                },
                "additionalProperties": true
              },
              "summary": {
                "$ref": "#/components/schemas/EndpointSummary"
              },
              "endpoints": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/EndpointResource"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metagraph.sh/schemas/provider.schema.json",
  "title": "Metagraphed Provider",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "kind",
    "website_url",
    "authority"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "enum": [
        "subnet-team",
        "infrastructure-provider",
        "data-provider",
        "docs-provider",
        "registry"
      ]
    },
    "website_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
      "examples": ["https://example.com"]
    },
    "docs_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
      "examples": ["https://docs.example.com"]
    },
    "github_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
      "examples": ["https://github.com/example"]
    },
    "logo_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
      "examples": ["https://example.com/logo.png"],
      "description": "Curated/hand-picked provider logo (square, ideally >=128px). Display-only; the UI falls back to the website favicon when absent."
    },
    "social": {
      "type": "object",
      "additionalProperties": false,
      "description": "Curated social links (#745) — wins over the single-subnet borrow. Display-only; never feeds completeness.",
      "properties": {
        "x": {
          "type": "string",
          "format": "uri",
          "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
          "examples": ["https://x.com/example"]
        },
        "telegram": {
          "type": "string",
          "format": "uri",
          "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
          "examples": ["https://t.me/example"]
        },
        "reddit": {
          "type": "string",
          "format": "uri",
          "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
          "examples": ["https://reddit.com/r/example"]
        },
        "youtube": {
          "type": "string",
          "format": "uri",
          "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
          "examples": ["https://youtube.com/@example"]
        }
      }
    },
    "team_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
      "examples": ["https://example.com/team"]
    },
    "contact_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
      "examples": ["https://example.com/contact"]
    },
    "authority": {
      "enum": ["official", "provider-claimed", "community", "registry-observed"]
    },
    "public_notes": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
